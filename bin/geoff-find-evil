#!/usr/bin/env python3
"""
geoff-find-evil — command-line interface for Geoff's Find Evil pipeline.

Usage:
    geoff-find-evil /path/to/evidence [options]

Options:
    -j, --json          Write full JSON report to stdout (suppresses progress output)
    -o, --output FILE   Write full JSON report to FILE as well as showing progress
    --no-color          Disable ANSI colour output
    --strict            Exit 2 on any step failure (default: continue on failure)
    -h, --help          Show this help and exit

Exit codes:
    0   Analysis complete — no evil found
    1   Analysis complete — evil found
    2   Error (bad path, unexpected exception)
"""

import argparse
import json
import os
import sys
import threading
import time
import uuid
from pathlib import Path

# ---------------------------------------------------------------------------
# Path setup — works whether run from repo root, bin/, or after pip install
# ---------------------------------------------------------------------------
_HERE = Path(__file__).resolve()
_SRC = _HERE.parent.parent / "src"
if str(_SRC) not in sys.path:
    sys.path.insert(0, str(_SRC))


# ---------------------------------------------------------------------------
# ANSI helpers
# ---------------------------------------------------------------------------

_BOLD   = "\033[1m"
_DIM    = "\033[2m"
_RED    = "\033[31m"
_YELLOW = "\033[33m"
_GREEN  = "\033[32m"
_CYAN   = "\033[36m"
_RESET  = "\033[0m"

_USE_COLOR = sys.stderr.isatty()


def _c(code: str, text: str) -> str:
    return f"{code}{text}{_RESET}" if _USE_COLOR else text


def _print_progress(msg: str):
    print(msg, file=sys.stderr, flush=True)


def _print_err(msg: str):
    print(_c(_RED, f"[error] {msg}"), file=sys.stderr, flush=True)


# ---------------------------------------------------------------------------
# Summary box
# ---------------------------------------------------------------------------

def _render_summary(report: dict) -> str:
    evil_found    = report.get("evil_found", False)
    classification = report.get("classification", "Unknown")
    severity      = report.get("severity", "UNKNOWN")
    pb_run        = len(report.get("playbooks_run", []))
    steps_ok      = report.get("steps_completed", 0)
    steps_fail    = report.get("steps_failed", 0)
    elapsed       = report.get("elapsed_seconds", 0)
    case_dir      = report.get("case_work_dir", "")
    chain         = report.get("attack_chain", {})
    dwell         = chain.get("dwell_days")
    mitre         = chain.get("mitre_techniques_observed", [])
    hits          = report.get("indicator_hits", [])
    hit_summary   = ", ".join(sorted({h.get("category","") for h in hits if h.get("category")}))

    severity_color = {
        "CRITICAL": _RED,
        "HIGH":     _YELLOW,
        "MEDIUM":   _CYAN,
        "LOW":      _DIM,
        "INFO":     _DIM,
    }.get(severity, _RESET)

    evil_str = (_c(_RED, _c(_BOLD, "YES")) if evil_found else _c(_GREEN, "no"))

    dwell_str = f"{dwell} days" if dwell is not None else "unknown"
    mitre_str = ", ".join(mitre[:8]) + (" …" if len(mitre) > 8 else "") if mitre else "none"

    W = 60
    bar = "─" * W

    lines = [
        "",
        _c(_BOLD, "┌" + bar + "┐"),
        _c(_BOLD, "│") + _c(_BOLD, " GEOFF FIND EVIL — INVESTIGATION COMPLETE").center(W) + _c(_BOLD, "│"),
        _c(_BOLD, "├" + bar + "┤"),
    ]

    def row(label: str, value: str) -> str:
        label_w = 22
        value_w = W - label_w - 3
        return _c(_BOLD, "│") + f"  {label:<{label_w}}" + f"{value:<{value_w}}" + _c(_BOLD, "│")

    lines += [
        row("Evil found:",      evil_str),
        row("Classification:",  classification),
        row("Severity:",        _c(severity_color, severity)),
        row("Playbooks run:",   str(pb_run)),
        row("Steps completed:", f"{steps_ok}  ({steps_fail} failed)"),
        row("Elapsed:",         f"{elapsed:.1f}s"),
        row("Dwell time:",      dwell_str),
    ]
    if hit_summary:
        lines.append(row("Indicators:", hit_summary))
    if mitre_str != "none":
        lines.append(row("MITRE techniques:", mitre_str))
    if case_dir:
        lines.append(row("Case directory:", case_dir))

    lines += [
        _c(_BOLD, "└" + bar + "┘"),
        "",
    ]
    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Log-tailing thread
# ---------------------------------------------------------------------------

def _tail_logs(job_id: str, jobs_store: dict, stop_event: threading.Event,
               quiet: bool):
    """Print new log entries from the job store as they arrive."""
    last_idx = 0
    while not stop_event.is_set():
        with_lock = jobs_store.get(job_id, {})
        log = with_lock.get("log", [])
        for entry in log[last_idx:]:
            if not quiet:
                ts  = entry.get("time", "")
                msg = entry.get("msg", "")
                _print_progress(f"{_c(_DIM, ts)}  {msg}")
            last_idx += 1
        time.sleep(0.05)
    # Drain any remaining entries after stop signal
    log = jobs_store.get(job_id, {}).get("log", [])
    for entry in log[last_idx:]:
        if not quiet:
            ts  = entry.get("time", "")
            msg = entry.get("msg", "")
            _print_progress(f"{_c(_DIM, ts)}  {msg}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="geoff-find-evil",
        description="Geoff DFIR — autonomous forensic triage and investigation.",
        add_help=False,
    )
    parser.add_argument("evidence_dir", nargs="?",
                        help="Path to evidence directory")
    parser.add_argument("-j", "--json", action="store_true",
                        help="Write full JSON report to stdout")
    parser.add_argument("-o", "--output", metavar="FILE",
                        help="Write full JSON report to FILE")
    parser.add_argument("--no-color", action="store_true",
                        help="Disable ANSI colour")
    parser.add_argument("--strict", action="store_true",
                        help="Treat any step failure as fatal (exit 2)")
    parser.add_argument("-h", "--help", action="store_true",
                        help="Show help and exit")
    args = parser.parse_args()

    if args.help or not args.evidence_dir:
        print(__doc__, file=sys.stderr)
        sys.exit(0)

    global _USE_COLOR
    if args.no_color:
        _USE_COLOR = False

    if args.strict:
        os.environ["GEOFF_CONTINUE_ON_FAILURE"] = "false"

    evidence_dir = str(Path(args.evidence_dir).resolve())
    if not Path(evidence_dir).exists():
        _print_err(f"Path not found: {evidence_dir}")
        sys.exit(2)

    # ------------------------------------------------------------------
    # Import geoff_integrated (heavy — Flask starts but we won't serve it)
    # ------------------------------------------------------------------
    quiet = args.json  # suppress progress when JSON mode requested

    if not quiet:
        _print_progress("")
        _print_progress(_c(_BOLD, "  Geoff DFIR — Find Evil"))
        _print_progress(f"  Evidence: {_c(_CYAN, evidence_dir)}")
        _print_progress("")

    try:
        import geoff_integrated as gi
    except Exception as e:
        _print_err(f"Failed to import geoff_integrated: {e}")
        sys.exit(2)

    # Register a job so _fe_log writes to the store we can tail
    job_id = str(uuid.uuid4())
    with gi._state_lock:
        gi._find_evil_jobs[job_id] = {
            "status": "running",
            "progress_pct": 0,
            "log": [],
            "started_at": time.time(),
        }

    # Start log-tailing thread
    stop_tailing = threading.Event()
    tailer = threading.Thread(
        target=_tail_logs,
        args=(job_id, gi._find_evil_jobs, stop_tailing, quiet),
        daemon=True,
    )
    tailer.start()

    # Run find_evil in a thread so KeyboardInterrupt works
    result_holder: dict = {}
    exc_holder:    dict = {}

    def _worker():
        try:
            result_holder["report"] = gi.find_evil(evidence_dir, job_id=job_id)
        except Exception as e:
            exc_holder["error"] = e

    worker = threading.Thread(target=_worker, daemon=True)
    worker.start()

    try:
        while worker.is_alive():
            worker.join(timeout=0.25)
    except KeyboardInterrupt:
        _print_progress("\n  Interrupted — waiting for current step to finish…")
        worker.join(timeout=10)

    # Stop tailer and drain remaining logs
    stop_tailing.set()
    tailer.join(timeout=2)

    # ------------------------------------------------------------------
    # Handle outcome
    # ------------------------------------------------------------------
    if exc_holder:
        _print_err(f"find_evil raised an exception: {exc_holder['error']}")
        sys.exit(2)

    report = result_holder.get("report", {})

    if report.get("status") == "error":
        _print_err(report.get("error", "unknown error"))
        sys.exit(2)

    # Write JSON report if requested
    if args.output:
        try:
            with open(args.output, "w") as fh:
                json.dump(report, fh, indent=2, default=str)
            if not quiet:
                _print_progress(f"\n  Report written to: {args.output}")
        except OSError as e:
            _print_err(f"Could not write report to {args.output}: {e}")

    if args.json:
        print(json.dumps(report, indent=2, default=str))
    else:
        print(_render_summary(report), file=sys.stderr)

    # Exit code: 1 = evil found, 0 = clean, 2 = error (handled above)
    evil_found = report.get("evil_found", False)
    steps_failed = report.get("steps_failed", 0)
    if args.strict and steps_failed > 0:
        sys.exit(2)
    sys.exit(1 if evil_found else 0)


if __name__ == "__main__":
    main()
