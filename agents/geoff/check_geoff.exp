#!/usr/bin/expect -f
set timeout 10
set user "sansforensics"
set password "forensics"
set ip "127.0.0.1"
set port "2222"

spawn ssh -o "StrictHostKeyChecking=no" -p $port $user@$ip "curl -I http://localhost:8080; ps aux | grep -i geoff"
expect {
    "*password:*" { send "$password\r" }
}
expect eof
